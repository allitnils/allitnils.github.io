---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { AUTHOR } from '../../data/author';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPost = allPosts.find(p => p.data.featured);
const restPosts = allPosts.filter(p => p !== featuredPost);
---
<BaseLayout
  title="Blog"
  description={`Writing on enterprise infrastructure, cloud architecture, observability, agentic AI, and the phenomenology of distributed work — by ${AUTHOR.name}.`}
>
  <div class="site-container" style="padding-top:4rem;padding-bottom:6rem;">
    <h1 style="font-weight:700;font-size:clamp(2rem,4vw,3rem);letter-spacing:-0.04em;margin:0 0 0.5rem;">Blog</h1>
    <p style="color:var(--text-secondary);margin:0 0 3rem;max-width:55ch;line-height:1.7;">
      Writing on enterprise architecture, observability, agentic AI systems, and the phenomenology of distributed work.
    </p>

    {featuredPost && (
      <PostCard
        title={featuredPost.data.title}
        description={featuredPost.data.description}
        pubDate={featuredPost.data.pubDate}
        slug={featuredPost.id}
        tags={featuredPost.data.tags}
        featured={true}
      />
    )}

    <div style="display:flex;flex-direction:column;gap:1rem;margin-top:1.5rem;">
      {restPosts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.id}
          tags={post.data.tags}
        />
      ))}
    </div>
  </div>
</BaseLayout>
