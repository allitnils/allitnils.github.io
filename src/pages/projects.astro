const allTopics = [...new Set(projects.flatMap(p => p.topics))].sort();
const categoryOrder = ['Work', 'Research', 'Tools'];

const statusColour: Record<string, string> = {
  'Active':     'var(--accent)',
  'Production': '#16a34a',
  'Live':       '#16a34a',
  'Completed':  'var(--text-muted)',
};

const projectsJson = JSON.stringify(projects.map(p => ({
  title: p.title, category: p.category, topics: p.topics, status: p.status,
  description: p.description, stack: p.stack, highlights: p.highlights,
  link: p.link, github: p.github,
})));
---
<BaseLayout
  title="Projects — Ivan Ocampo"
  description="Technical projects by Ivan Ocampo — enterprise observability, agentic AI workflows, NLP and sentiment analysis, browser tools, and research LaTeX templates. Chief Architect at Accent Group, Melbourne."
>
  <div class="site-container" style="padding-top:4rem;padding-bottom:6rem;">
    <h1 style="font-weight:700;font-size:clamp(2rem,4vw,3rem);letter-spacing:-0.04em;margin:0 0 0.5rem;">Projects</h1>
    <p style="font-size:1rem;color:var(--text-secondary);margin:0 0 2.5rem;max-width:58ch;line-height:1.7;">
      A selection of technical work — production systems, research tooling, and applied experiments spanning infrastructure, AI, and data science.
    </p>

    <!-- Topic filter -->
    <div style="margin-bottom:2.5rem;padding:1.25rem;background:var(--mid);border:1px solid var(--border);border-radius:8px;">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.875rem;flex-wrap:wrap;">
        <span style="font-weight:700;font-size:0.6875rem;letter-spacing:0.07em;text-transform:uppercase;color:var(--text-muted);">Filter by topic</span>
        <button id="clear-filter" style="display:none;font-size:0.75rem;color:var(--accent);background:none;border:none;cursor:pointer;padding:0;font-weight:500;">Clear &times;</button>
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:0.4rem;">
        {allTopics.map(topic => (
          <button
            class="topic-btn"
            data-topic={topic}
            style="font-family:'Fira Code Variable',monospace;font-size:0.6875rem;padding:0.25rem 0.6rem;border:1px solid var(--border);border-radius:4px;background:var(--paper);color:var(--text-secondary);cursor:pointer;transition:all 0.15s;"
          >{topic}</button>
        ))}
      </div>
    </div>

    <!-- Category count -->
    <p id="project-count" style="font-family:'Fira Code Variable',monospace;font-size:0.75rem;color:var(--text-muted);margin:0 0 2rem;">{projects.length} projects</p>

    <!-- Project list -->
    <div id="project-list"></div>
    <p id="no-results" style="display:none;color:var(--text-muted);font-size:0.9375rem;padding:2rem 0;">No projects match that topic.</p>

    <div style="padding-top:2rem;border-top:1px solid var(--border);margin-top:2rem;">
      <a href="/about" style="color:var(--accent);font-weight:500;text-decoration:none;font-size:0.875rem;">About Ivan Ocampo &rarr;</a>
    </div>
  </div>

  <script define:vars={{ projectsJson, categoryOrder, statusColour }}>
    const projects = JSON.parse(projectsJson);
    let activeTopic = null;

    const params = new URLSearchParams(window.location.search);
    if (params.get('topic')) activeTopic = params.get('topic');

    function chip(s) {
      return `<span style="font-family:'Fira Code Variable',monospace;font-size:0.625rem;padding:0.15rem 0.45rem;border:1px solid var(--border);border-radius:3px;color:var(--text-muted);background:var(--mid);">${s}</span>`;
    }

    function renderProjects() {
      const filtered = activeTopic ? projects.filter(p => p.topics.includes(activeTopic)) : projects;
      const list = document.getElementById('project-list');
      const none = document.getElementById('no-results');
      const count = document.getElementById('project-count');
      const clearBtn = document.getElementById('clear-filter');

      clearBtn.style.display = activeTopic ? 'inline' : 'none';
      count.textContent = filtered.length + (filtered.length === 1 ? ' project' : ' projects') + (activeTopic ? ` — ${activeTopic}` : '');

      document.querySelectorAll('.topic-btn').forEach(btn => {
        const active = btn.dataset.topic === activeTopic;
        btn.style.background = active ? 'var(--accent)' : 'var(--paper)';
        btn.style.color = active ? '#fff' : 'var(--text-secondary)';
        btn.style.borderColor = active ? 'var(--accent)' : 'var(--border)';
      });

      if (filtered.length === 0) {
        list.innerHTML = '';
        none.style.display = 'block';
        return;
      }
      none.style.display = 'none';

      // Group by category
      const grouped = categoryOrder.map(cat => ({
        cat,
        items: filtered.filter(p => p.category === cat),
      })).filter(g => g.items.length > 0);

      list.innerHTML = grouped.map(({ cat, items }) => `
        <div style="margin-bottom:3.5rem;">
          <h2 style="font-weight:600;font-size:0.8125rem;letter-spacing:0.07em;text-transform:uppercase;color:var(--text-muted);margin:0 0 1.5rem;padding-bottom:0.75rem;border-bottom:1px solid var(--border);">${cat}</h2>
          <div style="display:flex;flex-direction:column;gap:1.25rem;">
            ${items.map(p => `
              <article style="padding:1.75rem;border:1px solid var(--border);border-radius:8px;background:var(--paper);transition:transform 0.15s,border-color 0.15s;"
                onmouseover="this.style.transform='translateY(-2px)';this.style.borderColor='var(--border-mid)'"
                onmouseout="this.style.transform='';this.style.borderColor='var(--border)'">
                <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;margin-bottom:0.625rem;">
                  <h3 style="font-weight:700;font-size:clamp(1rem,2vw,1.25rem);letter-spacing:-0.02em;margin:0;">
                    ${p.link
                      ? `<a href="${p.link}" target="_blank" rel="noopener noreferrer" style="color:var(--text-primary);text-decoration:none;">${p.title} ↗</a>`
                      : p.title
                    }
                  </h3>
                  <div style="display:flex;gap:0.5rem;align-items:center;flex-shrink:0;">
                    <span style="font-family:'Fira Code Variable',monospace;font-size:0.625rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:${statusColour[p.status] ?? 'var(--text-muted)'};">${p.status}</span>
                    ${p.github ? `<a href="${p.github}" target="_blank" rel="noopener noreferrer" style="font-family:'Fira Code Variable',monospace;font-size:0.6875rem;color:var(--text-muted);text-decoration:none;border:1px solid var(--border);padding:0.15rem 0.5rem;border-radius:4px;">GitHub ↗</a>` : ''}
                  </div>
                </div>

                <p style="font-size:0.9rem;color:var(--text-secondary);margin:0 0 1.125rem;line-height:1.7;">${p.description}</p>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;">
                  <div>
                    <p style="font-weight:700;font-size:0.6875rem;letter-spacing:0.06em;text-transform:uppercase;color:var(--text-muted);margin:0 0 0.5rem;">Highlights</p>
                    <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:0.375rem;">
                      ${p.highlights.map(h => `<li style="font-size:0.8rem;color:var(--text-secondary);line-height:1.5;padding-left:0.875rem;position:relative;"><span style="position:absolute;left:0;top:0.42rem;width:3px;height:3px;background:var(--accent);border-radius:50%;display:inline-block;"></span>${h}</li>`).join('')}
                    </ul>
                  </div>
                  <div>
                    <p style="font-weight:700;font-size:0.6875rem;letter-spacing:0.06em;text-transform:uppercase;color:var(--text-muted);margin:0 0 0.5rem;">Stack</p>
                    <div style="display:flex;flex-wrap:wrap;gap:0.375rem;">
                      ${p.stack.map(chip).join('')}
                    </div>
                  </div>
                </div>
              </article>
            `).join('')}
          </div>
        </div>
      `).join('');
    }

    document.querySelectorAll('.topic-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        activeTopic = activeTopic === btn.dataset.topic ? null : btn.dataset.topic;
        const url = new URL(window.location);
        if (activeTopic) url.searchParams.set('topic', activeTopic);
        else url.searchParams.delete('topic');
        window.history.replaceState({}, '', url);
        renderProjects();
      });
    });

    document.getElementById('clear-filter').addEventListener('click', () => {
      activeTopic = null;
      const url = new URL(window.location);
      url.searchParams.delete('topic');
      window.history.replaceState({}, '', url);
      renderProjects();
    });

    renderProjects();
  </script>
</BaseLayout>
