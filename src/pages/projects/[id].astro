---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((p, i) => ({
    params: { id: p.id },
    props: {
      project: p,
      prev: projects[i - 1] ?? null,
      next: projects[i + 1] ?? null,
    },
  }));
}

const { project: p, prev, next } = Astro.props;
---
<BaseLayout
  title={`${p.title} — Ivan Ocampo`}
  description={p.summary || p.description.slice(0, 160)}
>
  <div class="site-container" style="padding-top:3.5rem;padding-bottom:6rem;max-width:760px;">

    <a href="/projects"
       style="display:inline-flex;align-items:center;gap:0.375rem;font-size:0.8125rem;color:var(--text-muted);text-decoration:none;margin-bottom:2.5rem;transition:color 0.12s;"
       onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-muted)'">
      ← Projects
    </a>

    <!-- Header -->
    <div style="margin-bottom:1.75rem;">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.625rem;flex-wrap:wrap;">
        <span style="font-family:'Fira Code Variable',monospace;font-size:0.5625rem;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;padding:0.25rem 0.6rem;border-radius:4px;background:var(--accent-light, #FEF3C7);color:var(--accent);">{p.status}</span>
        <span style="font-family:'Fira Code Variable',monospace;font-size:0.625rem;color:var(--text-muted);">{p.category}</span>
      </div>
      <h1 style="font-weight:700;font-size:clamp(1.75rem,4vw,2.75rem);letter-spacing:-0.04em;margin:0 0 1.25rem;line-height:1.1;">{p.title}</h1>
      <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
        {p.githubUrl && (
          <a href={p.githubUrl} target="_blank" rel="noopener noreferrer"
             style="display:inline-flex;align-items:center;gap:0.375rem;font-size:0.8125rem;font-weight:500;padding:0.5rem 1rem;border:1px solid var(--border-mid);border-radius:6px;color:var(--text-primary);text-decoration:none;background:var(--paper);transition:border-color 0.12s;"
             onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border-mid)'">
            View on GitHub ↗
          </a>
        )}
        {p.demoUrl && p.demoUrl !== p.githubUrl && (
          <a href={p.demoUrl} target="_blank" rel="noopener noreferrer"
             style="display:inline-flex;align-items:center;gap:0.375rem;font-size:0.8125rem;font-weight:500;padding:0.5rem 1rem;border-radius:6px;color:#fff;text-decoration:none;background:var(--accent);transition:opacity 0.12s;"
             onmouseover="this.style.opacity='0.88'" onmouseout="this.style.opacity='1'">
            Live Demo →
          </a>
        )}
      </div>
    </div>

    <!-- Stack badges -->
    {p.stack.length > 0 && (
      <div style="display:flex;flex-wrap:wrap;gap:0.375rem;margin-bottom:2.25rem;padding-bottom:2rem;border-bottom:1px solid var(--border);">
        {p.stack.map(s => (
          <span style="font-family:'Fira Code Variable',monospace;font-size:0.625rem;padding:0.2rem 0.5rem;border:1px solid var(--border);border-radius:3px;color:var(--text-muted);background:var(--mid);">{s}</span>
        ))}
      </div>
    )}

    <!-- About -->
    <section style="margin-bottom:2.5rem;">
      <h2 style="font-weight:700;font-size:0.6875rem;letter-spacing:0.07em;text-transform:uppercase;color:var(--text-muted);margin:0 0 1rem;">About this project</h2>
      <p style="font-size:1rem;color:var(--text-secondary);line-height:1.8;margin:0;">{p.description}</p>
    </section>

    <!-- Highlights -->
    {p.highlights.length > 0 && (
      <section style="margin-bottom:2.5rem;">
        <h2 style="font-weight:700;font-size:0.6875rem;letter-spacing:0.07em;text-transform:uppercase;color:var(--text-muted);margin:0 0 1rem;">Highlights</h2>
        <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:0.5rem;">
          {p.highlights.map(h => (
            <li style="font-size:0.9rem;color:var(--text-secondary);line-height:1.6;padding-left:1rem;position:relative;">
              <span style="position:absolute;left:0;top:0.6rem;width:3px;height:3px;background:var(--accent);border-radius:50%;display:inline-block;"></span>
              {h}
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Footer row -->
    <div style="display:flex;justify-content:space-between;align-items:center;padding-top:2rem;border-top:1px solid var(--border);margin-top:1rem;flex-wrap:wrap;gap:1rem;">
      <div style="display:flex;gap:1.25rem;align-items:center;">
        <a href="/projects"
           style="font-size:0.8125rem;color:var(--text-muted);text-decoration:none;transition:color 0.12s;"
           onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-muted)'">
          ← All projects
        </a>
        {p.githubUrl && (
          <a href={p.githubUrl} target="_blank" rel="noopener noreferrer"
             style="font-size:0.8125rem;color:var(--text-muted);text-decoration:none;transition:color 0.12s;"
             onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-muted)'">
            GitHub ↗
          </a>
        )}
      </div>
      <div style="display:flex;gap:1rem;">
        {prev && (
          <a href={`/projects/${prev.id}`}
             style="font-size:0.8125rem;color:var(--text-muted);text-decoration:none;transition:color 0.12s;"
             onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-muted)'">
            ← {prev.title}
          </a>
        )}
        {next && (
          <a href={`/projects/${next.id}`}
             style="font-size:0.8125rem;color:var(--text-muted);text-decoration:none;transition:color 0.12s;"
             onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-muted)'">
            {next.title} →
          </a>
        )}
      </div>
    </div>

  </div>
</BaseLayout>
