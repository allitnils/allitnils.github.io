---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: readonly string[];
  featured?: boolean;
}
const { title, description, pubDate, slug, tags = [], featured = false } = Astro.props;
const dateStr = pubDate.toLocaleDateString('en-AU', { year: 'numeric', month: 'short', day: 'numeric' });
---
{featured ? (
  <a href={`/blog/${slug}/`} class="post-card" style="display:block;padding:2rem;text-decoration:none;color:inherit;margin-bottom:1.5rem;">
    <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-bottom:1rem;">
      <span class="tag-chip" style="background:var(--accent);color:#fff;border-color:var(--accent);">Featured</span>
      {tags.slice(0,3).map(t => <span class="tag-chip">{t}</span>)}
    </div>
    <h2 style="font-weight:800;font-size:clamp(1.25rem,2.5vw,1.6rem);letter-spacing:-0.025em;margin:0 0 0.75rem;line-height:1.25;">{title}</h2>
    <p style="color:var(--text-secondary);line-height:1.7;margin:0 0 1rem;">{description}</p>
    <time style="font-family:'Fira Code Variable',monospace;font-size:0.75rem;color:var(--text-muted);">{dateStr}</time>
  </a>
) : (
  <a href={`/blog/${slug}/`} class="post-card" style="display:flex;flex-direction:column;padding:1.5rem;text-decoration:none;color:inherit;gap:0.5rem;">
    <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
      {tags.slice(0,3).map(t => <span class="tag-chip">{t}</span>)}
    </div>
    <h3 style="font-weight:700;font-size:1.0625rem;letter-spacing:-0.015em;margin:0;line-height:1.35;">{title}</h3>
    <p style="color:var(--text-secondary);font-size:0.9375rem;line-height:1.6;margin:0;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{description}</p>
    <time style="font-family:'Fira Code Variable',monospace;font-size:0.6875rem;color:var(--text-muted);">{dateStr}</time>
  </a>
)}
