---
const pathname = Astro.url.pathname;
const navLinks = [
  { href: '/',         label: 'Home' },
  { href: '/blog',     label: 'Blog' },
  { href: '/research', label: 'Research' },
  { href: '/teaching', label: 'Teaching' },
  { href: '/projects', label: 'Projects' },
  { href: '/about',    label: 'About' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---
<header class="site-header">
  <div class="site-container">
    <nav style="display:flex;align-items:center;justify-content:space-between;height:3.5rem;">
      <a href="/" style="display:flex;align-items:center;gap:0.375rem;text-decoration:none;color:var(--text-primary);">
        <span style="font-family:'Fira Code Variable',monospace;font-size:0.875rem;color:var(--accent);font-weight:500;">$</span>
        <span style="font-weight:600;font-size:0.9375rem;letter-spacing:-0.01em;">Ivan Ocampo</span>
      </a>
      <div style="display:flex;align-items:center;gap:1.5rem;">
        <ul style="display:flex;gap:1.5rem;list-style:none;margin:0;padding:0;">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                style={`text-decoration:none;font-size:0.875rem;font-weight:500;color:${isActive(link.href) ? 'var(--accent)' : 'var(--text-secondary)'};padding-bottom:2px;${isActive(link.href) ? 'border-bottom:2px solid var(--accent);' : ''}`}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <button
          id="theme-toggle"
          class="theme-toggle"
          aria-label="Toggle colour scheme"
          title="Toggle light / dark / system"
        >
          <span id="theme-icon">◐</span>
        </button>
      </div>
    </nav>
  </div>
</header>

<script>
  const ICONS: Record<string, string> = { light: '☀', dark: '☾', system: '◐' };
  const CYCLE: string[] = ['system', 'light', 'dark'];

  function getTheme(): string {
    return localStorage.getItem('theme') || 'system';
  }

  function applyTheme(theme: string) {
    if (theme === 'system') {
      document.documentElement.removeAttribute('data-theme');
    } else {
      document.documentElement.setAttribute('data-theme', theme);
    }
    const icon = document.getElementById('theme-icon');
    if (icon) icon.textContent = ICONS[theme] ?? '◐';
    localStorage.setItem('theme', theme);
  }

  // Init icon on load
  applyTheme(getTheme());

  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const current = getTheme();
    const next = CYCLE[(CYCLE.indexOf(current) + 1) % CYCLE.length];
    applyTheme(next);
  });
</script>
